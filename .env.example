# PostgreSQL (pgvector-enabled)
POSTGRES_USER=rfp
POSTGRES_PASSWORD=rfp_local_dev
POSTGRES_DB=rfp_pulse
POSTGRES_PORT=5432

# Prisma connection string (consumed by packages/db)
DATABASE_URL=postgresql://rfp:rfp_local_dev@localhost:5432/rfp_pulse?schema=public

# Backend API (NestJS)
API_PORT=4000
API_HOST=0.0.0.0

# Next.js web app
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXTAUTH_SECRET=replace-me-with-a-random-32-byte-string
NEXTAUTH_URL=http://localhost:3000

# LLM provider keys (added in Step 3)
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
LLAMA_API_KEY=

# AWS S3 (added in Step 4)
AWS_REGION=us-east-1
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
