// RFP Pulse — Prisma schema
// Multi-tenant, pool-based isolation: every non-Tenant table carries tenantId.
// pgvector is used for semantic search over knowledge base embeddings.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector, pg_trgm]
}

// ---------- Enums ----------

enum Role {
  SUPER_ADMIN
  ADMIN
  RFP_MANAGER
  SME
  REVIEWER
  APPROVER
  READ_ONLY
}

enum WorkflowState {
  DRAFTING
  IN_REVIEW
  PENDING_APPROVAL
  APPROVED
  REJECTED
}

enum LLMProvider {
  OPENAI
  GEMINI
  CLAUDE
  LLAMA
}

enum DocumentKind {
  RFP
  FOIA
  KNOWLEDGE
}

enum RFPStatus {
  DRAFT
  IN_PROGRESS
  UNDER_REVIEW
  APPROVED
  SUBMITTED
  WON
  LOST
  CANCELLED
}

// ---------- Tenancy & Users ----------

model Tenant {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  /// Per-tenant default LLM provider. Drives the Strategy factory in Step 3.
  defaultProvider LLMProvider @default(OPENAI)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  users             User[]
  rfpProjects       RFPProject[]
  knowledgeEntries  KnowledgeBaseEntry[]
  competitorIntel   CompetitorIntel[]
  documents         Document[]

  @@map("tenants")
}

model User {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email     String
  name      String?
  /// Password hash (only used when NextAuth credentials provider is enabled).
  passwordHash String?
  /// If true, the user must change their password on next login (e.g. after an admin invite).
  passwordMustChange Boolean @default(false)
  role      Role     @default(READ_ONLY)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignedQuestions   RFPQuestion[] @relation("AssignedSME")
  authoredAnswers     RFPAnswer[]   @relation("AnswerAuthor")
  reviewedAnswers     RFPAnswer[]   @relation("AnswerReviewer")
  createdRfpProjects  RFPProject[]  @relation("RFPProjectCreatedBy")
  assignedRfpProjects RFPProject[]  @relation("RFPProjectAssignee")

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("users")
}

// ---------- RFP Projects & Q/A ----------

model RFPProject {
  id          String    @id @default(cuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title       String
  clientName  String?
  dueAt       DateTime?
  /// Lifecycle status tracked at the RFP level (distinct from per-question
  /// WorkflowState on individual answers).
  status      RFPStatus @default(DRAFT)
  /// Creator (null for rows that predate this column). Preserved on user delete.
  createdById String?
  createdBy   User?     @relation("RFPProjectCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  /// Primary assignee for the RFP.
  assigneeId  String?
  assignee    User?     @relation("RFPProjectAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  questions RFPQuestion[]
  documents Document[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([createdById])
  @@index([assigneeId])
  @@map("rfp_projects")
}

model RFPQuestion {
  id             String   @id @default(cuid())
  tenantId       String
  projectId      String
  project        RFPProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  /// Raw question text extracted from the RFP document.
  questionText   String
  /// Optional section/heading context from the source document.
  sectionPath    String?
  assignedSmeId  String?
  assignedSme    User?    @relation("AssignedSME", fields: [assignedSmeId], references: [id])
  /// Whether the user has marked this question as "selected" for inclusion
  /// in the RFP response effort. Selected + assigned questions surface on
  /// the assignee's Tasks page.
  isSelected     Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  answers RFPAnswer[]

  @@index([tenantId])
  @@index([projectId])
  @@map("rfp_questions")
}

model RFPAnswer {
  id           String   @id @default(cuid())
  tenantId     String
  questionId   String
  question     RFPQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  /// Drafted response text. Generated by the RAG pipeline and edited by users.
  content      String
  state        WorkflowState @default(DRAFTING)
  /// Which LLM generated the initial draft, if any.
  generatedBy  LLMProvider?
  authorId     String?
  author       User?    @relation("AnswerAuthor", fields: [authorId], references: [id])
  reviewerId   String?
  reviewer     User?    @relation("AnswerReviewer", fields: [reviewerId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([tenantId])
  @@index([questionId])
  @@index([state])
  @@map("rfp_answers")
}

// ---------- Knowledge Base (RAG) ----------

model KnowledgeBaseEntry {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  /// Short label (often the original question or document section heading).
  title      String
  /// Canonical answer / chunk text that will be returned to the LLM.
  content    String
  /// Optional source provenance (document id, URL, etc.).
  source     String?
  /// 1536-dim OpenAI text-embedding-3-small vector. Adjustable in Step 3.
  embedding  Unsupported("vector(1536)")?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([tenantId])
  @@map("knowledge_base_entries")
}

// ---------- Tenant signup invites ----------

/// One-time signup invite generated by a SUPER_ADMIN. The raw token is only
/// shown once (via the admin UI); we store a sha256 hash for lookup. Redemption
/// creates a new Tenant + initial ADMIN user in a single transaction.
model TenantInvite {
  id               String    @id @default(cuid())
  /// sha256(token). Lookup is done by re-hashing the URL token.
  tokenHash        String    @unique
  invitedByUserId  String?
  /// Optional pre-filled email; the redeemer can still change it.
  intendedEmail    String?
  /// Optional pre-filled company name hint shown on the signup page.
  intendedCompany  String?
  expiresAt        DateTime
  usedAt           DateTime?
  /// Resulting tenant if the invite was redeemed. Non-null once consumed.
  redeemedTenantId String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([expiresAt])
  @@map("tenant_invites")
}

// ---------- Competitive Intelligence (FOIA) ----------

model CompetitorIntel {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  competitorName  String
  /// Full extracted text of the competitor document, for audit trail.
  rawText         String
  /// LLM-extracted pricing model summary.
  pricingModel    String?
  /// LLM-extracted win themes (stored as newline-delimited bullets for MVP).
  winThemes       String?
  /// LLM-extracted technical strategies.
  technicalStrategies String?
  sourceDocumentId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenantId])
  @@map("competitor_intel")
}

// ---------- Documents ----------

model Document {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  projectId  String?
  project    RFPProject? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  filename   String
  /// S3 object key (partitioned by tenantId) once Step 4 is wired.
  s3Key      String?
  mimeType   String
  sizeBytes  Int
  kind       DocumentKind
  /// Full extracted plain text (from pdf-parse / docx / xlsx / txt), used
  /// to power the RFP detail view and question-generation prompt. Nullable
  /// for historical rows that predate this column.
  extractedText String?
  /// Optional formatted HTML rendering (populated for DOCX via mammoth).
  /// When present, the detail viewer renders this instead of escaped text
  /// so headings/bold/lists/tables keep their formatting.
  extractedHtml String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([tenantId])
  @@index([projectId])
  @@map("documents")
}
